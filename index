function fmt(n) {
  return n.toLocaleString('lt-LT', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' €';
}
function fmtInt(n) {
  return Math.round(n).toLocaleString('lt-LT') + ' €';
}

function build() {
  const tbody = document.getElementById('table-body');
  let html = '';
  let totalNet = 0;
  let currentGroup = null;

  // Group totals
  const groupTotals = {};
  ITEMS.forEach(([g,,,,qty,,price]) => {
    groupTotals[g] = (groupTotals[g] || 0) + qty * price;
  });

  // Collect groups in order
  const groupOrder = [...new Set(ITEMS.map(i => i[0]))];
  let rowAlt = false;

  groupOrder.forEach(grp => {
    // Group header
    html += `<tr class="group-row">
      <td colspan="7"><span class="group-num">${grp}</span>${GROUPS[grp]}</td>
    </tr>`;

    const grpItems = ITEMS.filter(i => i[0] === grp);
    grpItems.forEach(([, nr, name, spec, qty, unit, price]) => {
      const net = qty * price;
      const gross = net * VAT;
      totalNet += net;
      const qtyStr = Number.isInteger(qty) ? qty : qty.toString().replace('.', ',');
      html += `<tr class="item-row ${rowAlt ? 'alt' : ''}">
        <td class="item-nr">${nr.split('.')[0]}</td>
        <td class="item-nr" style="text-align:center">${nr}</td>
        <td><div class="item-name">${name}</div><div class="item-spec">${spec}</div></td>
        <td class="num">${qtyStr}</td>
        <td class="unit">${unit}</td>
        <td class="num price-net">${fmtInt(net)}</td>
        <td class="num price-vat">${fmtInt(gross)}</td>
      </tr>`;
      rowAlt = !rowAlt;
    });

    // Subtotal
    const sNet = groupTotals[grp];
    const sGross = sNet * VAT;
    html += `<tr class="subtotal-row">
      <td colspan="5"><span class="subtotal-label">Iš viso — ${GROUPS[grp]}</span></td>
      <td class="subtotal-amt net">${fmtInt(sNet)}</td>
      <td class="subtotal-amt gross">${fmtInt(sGross)}</td>
    </tr>`;
  });

  tbody.innerHTML = html;

  const vatAmt = totalNet * 0.21;
  const gross = totalNet * VAT;
  document.getElementById('total-net').textContent = fmtInt(totalNet);
  document.getElementById('total-vat-amt').textContent = fmtInt(vatAmt);
  document.getElementById('grand-total').textContent = fmtInt(gross);
}

build();
</script>
