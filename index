  /* ── SIGNATURES ── */
  .sig-section {
    margin: 28px 48px 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: var(--fog);
    border: 1px solid var(--fog);
