  }
  .sig-hint {
    font-size: 9.5px;
    color: var(--mist);
  }

  /* ── FOOTER ── */
  .doc-footer {
    background: var(--ink);
    padding: 12px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
